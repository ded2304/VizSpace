<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        Title="Isovist Analysis"
        Height="400" Width="300"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="10">

        <TextBlock Text="Advanced Isovist Calculations"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <CheckBox x:Name="chkArea" Content="Isovist Area"/>
        <CheckBox x:Name="chkPerimeter" Content="Isovist Perimeter"/>
        <CheckBox x:Name="chkCompactness" Content="Compactness"/>
        <CheckBox x:Name="chkDrift" Content="Drift (Magnitude + Direction)"/>

        <Separator Margin="0,10,0,10"/>

        <Button x:Name="btnRun"
                Content="Compute Selected Metrics"
                Height="30"/>

        <TextBox x:Name="txtOutput"
                 Margin="0,10,0,0"
                 Height="150"
                 TextWrapping="Wrap"
                 IsReadOnly="True"/>

    </StackPanel>
</Window>